rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile Photos
    match /profile_photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Event Banners (Admin only)
    match /event_banners/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Temporarily allow without auth for debugging
    }
    
    // Ad Banners (Admin only)
    match /ad_banners/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Temporarily allow without auth for debugging
    }
  }
}
